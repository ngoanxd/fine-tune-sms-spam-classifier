   "source": [
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 106,
   "id": "4746afb5",
   "metadata": {},
   "outputs": [],
   "source": [
    "criterion = nn.NLLLoss()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 110,
   "id": "ecccf906",
   "metadata": {},
   "outputs": [],
   "source": [
    "def train():\n",
    "    custombert.train()\n",
    "    total_loss, total_accuracy = 0, 0\n",
    "    total_preds = []\n",
    "\n",
    "    for step, batch in enumerate(train_loader):\n",
    "\n",
    "        # chỉ để log\n",
    "        if step % 50 == 0 and step != 0:\n",
    "            print(f\"Batch {step}/{len(train_loader)}\")\n",
    "\n",
    "        batch = [r.to(device) for r in batch]\n",
    "        sentence_ids, mask_att, labels = batch\n",
    "\n",
    "        custombert.zero_grad()\n",
    "\n",
    "        preds = custombert(sentence_ids, mask_att)\n",
    "        loss = criterion(preds, labels)\n",
    "\n",
    "        total_loss += loss.item()\n",
    "\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(custombert.parameters(), 1.0)\n",
    "\n",
    "        optimizer.step()\n",
    "\n",
    "        preds_cpu = preds.detach().cpu().numpy()\n",
    "        labels_cpu = labels.detach().cpu().numpy()\n",
    "\n",
    "        pred_labels = np.argmax(preds_cpu, axis=1)\n",
    "        total_accuracy += (pred_labels == labels_cpu).sum()\n",
    "\n",
    "        total_preds.append(preds_cpu)\n",
    "\n",
    "    avg_loss = total_loss / len(train_loader)\n",
    "    avg_acc = total_accuracy / len(train_loader.dataset)\n",
    "\n",
    "    total_preds = np.concatenate(total_preds, axis=0)\n",
    "\n",
    "    return avg_loss, avg_acc, total_preds"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 111,
   "id": "ca069d98",
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate():\n",
    "    custombert.eval()\n",
    "\n",
    "    total_loss, total_acc = 0, 0\n",
    "    total_preds = []\n",
    "\n",
    "    for step, batch in enumerate(val_loader):\n",
    "\n",
    "        batch = [t.to(device) for t in batch]\n",
    "        sent_id, mask_att, labels = batch\n",
    "\n",
    "        with torch.no_grad():\n",
    "\n",
    "            preds = custombert(sent_id, mask_att)\n",
    "\n",
    "            loss = criterion(preds, labels)\n",
    "            total_loss += loss.item()\n",
    "\n",
    "            preds_cpu = preds.detach().cpu().numpy()\n",
    "            labels_cpu = labels.detach().cpu().numpy()\n",
    "\n",
    "            pred_labels = np.argmax(preds_cpu, axis=1)\n",
    "\n",
    "            total_acc += (pred_labels == labels_cpu).sum()\n",
    "\n",
    "            total_preds.append(preds_cpu)\n",
    "\n",
    "    avg_loss = total_loss / len(val_loader)\n",
    "    avg_acc = total_acc / len(val_loader.dataset)\n",
    "\n",
    "    total_preds = np.concatenate(total_preds, axis=0)\n",
    "\n",
    "    return avg_loss, avg_acc, total_preds"
   ]
  },
