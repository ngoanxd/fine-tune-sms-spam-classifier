   "source": [
    "import torch.nn as nn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "24bd3721",
   "metadata": {},
   "outputs": [],
   "source": [
    "for param in model.parameters():\n",
    "    param.requires_grad=False\n",
    "\n",
    "#defining new layers\n",
    "\n",
    "class Bert_Architecture(nn.Module):\n",
    "    def __init__(self,bert):\n",
    "        super(Bert_Architecture,self).__init__()\n",
    "        self.model=model\n",
    "\n",
    "        #dropout layer\n",
    "        self.dropout=nn.Dropout(0.3)\n",
    "\n",
    "        # relu activation function\n",
    "        self.relu=nn.ReLU()\n",
    "\n",
    "        # dense layer   1\n",
    "        self.fc1=nn.Linear(768,512)\n",
    "\n",
    "        #dense layer 2\n",
    "        self.fc2=nn.Linear(512,2)\n",
    "\n",
    "        # softmax activation function\n",
    "        self.softmax=nn.LogSoftmax(dim=1)\n",
    "\n",
    "\n",
    "    # define the forward pass\n",
    "    \n",
    "    def forward(self,ids_sentence,mask_att):\n",
    "        # pass the inputs to the model\n",
    "\n",
    "        _, cls_hs=self.model(ids_sentence,mask_att,return_dict=False) #bert model sẽ trả về last hidden state và pooler\n",
    "        x=self.fc1(cls_hs)\n",
    "        x=self.relu(x)\n",
    "        x=self.dropout(x)\n",
    "        #output layer\n",
    "        x=self.fc2(x)\n",
    "        # apply softmax activation \n",
    "        x=self.softmax(x)\n",
    "        return x\n",
    "\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 103,
   "id": "187b48cf",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch.optim as optim"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0e27138f",
   "metadata": {},
   "outputs": [],
   "source": [
    "custombert=Bert_Architecture(model)\n",
    "optimizer = optim.AdamW(custombert.parameters(), lr=3e-5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 105,
   "id": "2221bbde",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
